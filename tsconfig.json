{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "es2022",
      "DOM"
    ],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": false,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "types": [
      "node"
    ],
    "paths": {
      "/opt/nodejs/productsLayer": [
        "./lambda/products/layers/productsLayer/nodejs/productRepository"
      ],
      "/opt/nodejs/productEventsLayer": [
        "./lambda/products/layers/productEventsLayer/nodejs/productEvent.ts"
      ],

      "/opt/nodejs/ordersLayer": [
        "./lambda/orders/layers/ordersLayer/nodejs/orderRepository"
      ],

      "/opt/nodejs/ordersApiLayer": [
        "./lambda/orders/layers/ordersApiLayer/nodejs/orderApi"
      ],
      "/opt/nodejs/orderEventsLayer": [
        "./lambda/orders/layers/orderEventsLayer/nodejs/orderEvent"
      ],
      "/opt/nodejs/orderEventsRepositoryLayer": [
        "./lambda/orders/layers/orderEventsRepositoryLayer/nodejs/orderEventRepository"
      ],
    }
  },
  "exclude": [
    "node_modules",
    "cdk.out"
  ]
}